{
  "permissions": {
    "allow": [
      "Bash(npx tsc --noEmit)",
      "Bash(npm run lint)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(node scripts/verify-*)",
      "Bash(node scripts/db-apply.mjs --status)",
      "Bash(./scripts/dev-up.sh)",
      "mcp__Claude_in_Chrome__read_console_messages",
      "mcp__Claude_in_Chrome__tabs_context_mcp"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "git push origin HEAD 2>/dev/null || true",
            "async": true,
            "statusMessage": "Backing up to origin..."
          }
        ]
      }
    ]
  }
}
