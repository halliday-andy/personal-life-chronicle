{
  "$id": "https://lifechronicle.example/cef.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chronicle Exchange Format (CEF) v1 \u2014 Bundle",
  "type": "object",
  "properties": {
    "format": {
      "const": "chronicle-exchange"
    },
    "version": {
      "const": "v1"
    },
    "exportedAt": {
      "type": "string",
      "format": "date-time"
    },
    "generator": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ]
    },
    "hashes": {
      "type": "object",
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": [
            "sha256"
          ]
        },
        "files": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "algorithm",
        "files"
      ]
    }
  },
  "required": [
    "format",
    "version",
    "exportedAt",
    "generator"
  ],
  "$defs": {
    "Tier": {
      "type": "string",
      "enum": [
        "private",
        "close_friends",
        "family",
        "professional",
        "public"
      ]
    },
    "Entity": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "@type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "geo": {
          "type": [
            "object",
            "null"
          ]
        }
      },
      "required": [
        "id",
        "name"
      ]
    },
    "Event": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string",
          "const": "Event"
        },
        "start": {
          "type": [
            "string",
            "null"
          ]
        },
        "end": {
          "type": [
            "string",
            "null"
          ]
        },
        "fuzzy": {
          "type": [
            "string",
            "null"
          ]
        },
        "confidence": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "TranscriptRef": {
      "type": "object",
      "properties": {
        "vtt": {
          "type": "string"
        },
        "srt": {
          "type": [
            "string",
            "null"
          ]
        },
        "json": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "vtt"
      ]
    },
    "MediaItem": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "audio",
            "video",
            "image",
            "doc"
          ]
        },
        "path": {
          "type": "string"
        },
        "duration": {
          "type": [
            "number",
            "null"
          ]
        },
        "meta": {
          "type": [
            "object",
            "null"
          ]
        }
      },
      "required": [
        "type",
        "path"
      ]
    },
    "Entry": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "tier": {
          "$ref": "#/$defs/Tier"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "source": {
          "type": "string",
          "enum": [
            "user",
            "linkedin",
            "crawler"
          ]
        },
        "taxonomy": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "key": {
                "type": "string"
              },
              "label": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "required": [
              "key"
            ]
          }
        },
        "entities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Entity"
          }
        },
        "event": {
          "$ref": "#/$defs/Event"
        },
        "media": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MediaItem"
          }
        },
        "transcript": {
          "$ref": "#/$defs/TranscriptRef"
        },
        "citations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "format": "uri"
              },
              "title": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "capturedAt": {
                "type": [
                  "string",
                  "null"
                ],
                "format": "date-time"
              }
            }
          }
        },
        "consent": {
          "type": "object",
          "properties": {
            "voiceCloneAllowed": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "publicIndexingAllowed": {
              "type": [
                "boolean",
                "null"
              ]
            }
          }
        },
        "checksums": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "tier",
        "createdAt",
        "source",
        "transcript"
      ]
    },
    "Profile": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "displayName": {
          "type": [
            "string",
            "null"
          ]
        },
        "locale": {
          "type": [
            "string",
            "null"
          ]
        },
        "cadence": {
          "type": "object",
          "properties": {
            "minPrompts": {
              "type": [
                "integer",
                "null"
              ]
            },
            "maxPrompts": {
              "type": [
                "integer",
                "null"
              ]
            }
          }
        }
      },
      "required": [
        "userId"
      ]
    },
    "Entities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Entity"
      }
    },
    "Taxonomy": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string"
        },
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "parentId": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "nodeType": {
                "type": "string",
                "enum": [
                  "series",
                  "topic",
                  "question"
                ]
              },
              "key": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "sensitivity": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "defaultTier": {
                "$ref": "#/$defs/Tier"
              }
            },
            "required": [
              "id",
              "nodeType",
              "key",
              "label"
            ]
          }
        }
      },
      "required": [
        "version",
        "nodes"
      ]
    },
    "Events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Event"
      }
    }
  }
}