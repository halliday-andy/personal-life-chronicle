# ============================================================
# Life Chronicle — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# Supabase project URL (public — safe for client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon key (public — safe for client-side, governed by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key — PRIVATE, SERVER-SIDE ONLY
# Bypasses RLS entirely. Used only by agent functions and admin operations.
# Must NEVER appear in browser-side code or be returned in API responses.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App base URL
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ============================================================
# Future additions (not required for Step 1)
# ============================================================

# Inngest event key (for agent orchestration)
# INNGEST_EVENT_KEY=...
# INNGEST_SIGNING_KEY=...

# LLM provider (for Capture, Tagger, Synthesis agents)
# ANTHROPIC_API_KEY=...

# Geocoding (for Entity Agent place resolution)
# GOOGLE_MAPS_API_KEY=...

# Analytics (PostHog)
# NEXT_PUBLIC_POSTHOG_KEY=...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
